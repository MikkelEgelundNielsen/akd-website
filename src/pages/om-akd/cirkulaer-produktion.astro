---
import BaseLayout from '@/layouts/BaseLayout.astro'
import ContentBox from '@/components/sections/ContentBox.astro'
import ProcessSteps from '@/components/sections/ProcessSteps.astro'
import PortableText from '@/components/sanity/PortableText.astro'
import { sanityClient } from '@/lib/sanity'
import { circularProductionPageQuery } from '@/lib/sanityQueries'
import { portableTextToHtml } from '@/lib/portableTextSerializer'
import type { CircularProductionPage } from '@/types/sanity'

export const prerender = true;

let page: CircularProductionPage | null = null
try {
  page = await sanityClient.fetch<CircularProductionPage>(circularProductionPageQuery)
} catch (error) {
  console.error('Error fetching Circular Production page from Sanity:', error)
}

if (!page) {
  return Astro.redirect('/404')
}

const headlineHtml = page.hero?.headline
  ? portableTextToHtml(page.hero.headline, { addHeadingIds: false })
  : ''

const introHtml = page.hero?.introText
  ? portableTextToHtml(page.hero.introText, { addHeadingIds: false })
  : ''

const preHeadline = page.hero?.preHeadline

const metaTitle = page.seo?.metaTitle || page.title || 'Cirkulær produktion'
const metaDescription = page.seo?.metaDescription || ''

const intro = page.introSection
const contentBox = page.contentBox
const contentBoxItems = contentBox?.items || []
const process = page.processSection
const byproducts = page.byproductsSection
const local = page.localSection
const energy = page.energySection
const relevanceBox = page.relevanceContentBox
const relevanceBoxItems = relevanceBox?.items || []
const cta = page.ctaSection

const processSteps = (process?.steps || []).map((step, i) => ({
  number: i + 1,
  title: step.title,
  description: step.text,
}))
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  navTheme="light"
>

  <!-- SECTION 1: HERO -->
  <section class="relative bg-warm-light pt-12 md:pt-16 lg:pt-20 pb-16 md:pb-24 section-after-nav">
    <div class="container-custom">
      {preHeadline && (
        <p class="text-mint-dark font-bold text-base mb-6 uppercase tracking-wide text-center">
          {preHeadline}
        </p>
      )}

      {headlineHtml && (
        <h1 class="text-center mb-8 md:mb-12 max-w-4xl mx-auto">
          <span class="block font-sans font-extrabold text-[43px] md:text-[58px] lg:text-[62px] text-charcoal uppercase leading-tight [&_.font-serif]:lowercase [&_.font-serif]:font-medium" set:html={headlineHtml} />
        </h1>
      )}

      {introHtml && (
        <div class="max-w-3xl mx-auto text-center text-charcoal text-lg md:text-xl leading-relaxed prose-akd mb-10" set:html={introHtml} />
      )}

      {(page.primaryCtaUrl || page.secondaryCtaUrl) && (
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
          {page.secondaryCtaUrl && (
            <a href={page.secondaryCtaUrl} class="btn-secondary">
              {page.secondaryCtaText}
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          )}
          {page.primaryCtaUrl && (
            <a href={page.primaryCtaUrl} class="btn-primary">
              <span>{page.primaryCtaText}</span>
              <span class="btn-icon-circle">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </span>
            </a>
          )}
        </div>
      )}
    </div>
  </section>


  <!-- SECTION 2: INTRO -->
  {intro && (
    <section class="bg-white py-16 md:py-24">
      <div class="container-custom">
        <div class="max-w-4xl mx-auto">
          {intro.heading && (
            <h2 class="font-serif font-semibold italic text-4xl md:text-[43px] text-charcoal leading-tight mb-8 text-center">
              {intro.heading}
            </h2>
          )}
          {intro.body && (
            <div class="text-charcoal/80 text-lg md:text-xl leading-relaxed text-center">
              <PortableText content={intro.body} addHeadingIds={false} />
            </div>
          )}
        </div>
      </div>
    </section>
  )}


  <!-- SECTION 3: CONTENT BOX (Principper) -->
  {contentBox && (
    <section class="relative bg-warm-light py-16 md:py-24">
      <ContentBox
        variant={contentBox.variant || 'light'}
        layout={contentBox.layout || 'full-width'}
        preHeader={contentBox.preHeader}
        headline={contentBox.headline}
        imageUrl={contentBox.image || ''}
        imageAlt={contentBox.imageAlt || ''}
        pullUp={contentBox.pullUp || 0}
        items={contentBoxItems}
      />
    </section>
  )}


  <!-- SECTION 4: PROCESS -->
  {process && processSteps.length > 0 && (
    <section class="bg-white py-16 md:py-24">
      <div class="container-custom">
        <div class="max-w-3xl mx-auto">
          <h2 class="font-sans font-bold text-2xl md:text-3xl text-charcoal text-center mb-4">
            {process.heading}
          </h2>
          {process.introText && (
            <p class="text-charcoal/70 text-lg md:text-xl leading-relaxed text-center mb-12">
              {process.introText}
            </p>
          )}

          <ProcessSteps steps={processSteps} variant="light" />
        </div>
      </div>
    </section>
  )}


  <!-- SECTION 5: BYPRODUCTS 
  {byproducts && (
    <section class="bg-warm-light py-16 md:py-24">
      <div class="container-custom">
        <div class="max-w-4xl mx-auto">
          {byproducts.heading && (
            <h2 class="font-sans font-bold text-2xl md:text-3xl text-charcoal mb-6">
              {byproducts.heading}
            </h2>
          )}
          {byproducts.body && (
            <div class="text-charcoal/80 text-lg md:text-xl leading-relaxed mb-8">
              <PortableText content={byproducts.body} addHeadingIds={false} />
            </div>
          )}
          {byproducts.linkHref && (
            <a href={byproducts.linkHref} class="link-arrow">
              {byproducts.linkText}
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          )}
        </div>
      </div>
    </section>
  )}-->


  <!-- SECTION 6: LOCAL LOOPS -->
  {local && (
    <section class="bg-white py-16 md:py-24">
      <div class="container-custom">
        <div class="max-w-4xl mx-auto">
          {local.heading && (
            <h2 class="font-sans font-bold text-2xl md:text-3xl text-charcoal mb-6">
              {local.heading}
            </h2>
          )}
          {local.body && (
            <div class="text-charcoal/80 text-lg md:text-xl leading-relaxed">
              <PortableText content={local.body} addHeadingIds={false} />
            </div>
          )}
        </div>
      </div>
    </section>
  )}


  <!-- SECTION 7: ENERGY -->
  {energy && (
    <section class="bg-warm-light py-16 md:py-24">
      <div class="container-custom">
        <div class="max-w-4xl mx-auto">
          {energy.heading && (
            <h2 class="font-sans font-bold text-2xl md:text-3xl text-charcoal mb-6">
              {energy.heading}
            </h2>
          )}
          {energy.body && (
            <div class="text-charcoal/80 text-lg md:text-xl leading-relaxed">
              <PortableText content={energy.body} addHeadingIds={false} />
            </div>
          )}
        </div>
      </div>
    </section>
  )}


  <!-- SECTION 8: RELEVANCE CONTENT BOX -->
  {relevanceBox && (
    <section class="relative bg-white py-16 md:py-24">
      <ContentBox
        variant={relevanceBox.variant || 'light'}
        layout={relevanceBox.layout || 'full-width'}
        preHeader={relevanceBox.preHeader}
        headline={relevanceBox.headline}
        imageUrl={relevanceBox.image || ''}
        imageAlt={relevanceBox.imageAlt || ''}
        pullUp={relevanceBox.pullUp || 0}
        items={relevanceBoxItems}
      />
    </section>
  )}


  <!-- SECTION 9: CTA BAND -->
  {cta && (
    <section class="bg-charcoal py-16 md:py-24">
      <div class="container-custom">
        <div class="max-w-4xl mx-auto text-center">
          {cta.heading && (
            <h2 class="font-sans font-bold text-2xl md:text-3xl text-white mb-4">
              {cta.heading}
            </h2>
          )}
          {cta.introText && (
            <p class="text-white/70 text-lg mb-10">
              {cta.introText}
            </p>
          )}

          {cta.ctas && cta.ctas.length > 0 && (
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6">
              {cta.ctas.map((ctaItem, index) => (
                index === 0 ? (
                  <a href={ctaItem.href} class="btn-primary">
                    <span>{ctaItem.label}</span>
                    <span class="btn-icon-circle">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                      </svg>
                    </span>
                  </a>
                ) : (
                  <a href={ctaItem.href} class="btn-secondary">
                    {ctaItem.label}
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                  </a>
                )
              ))}
            </div>
          )}
        </div>
      </div>
    </section>
  )}

</BaseLayout>
